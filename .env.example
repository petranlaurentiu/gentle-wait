# Public app configuration
# These values are intentionally available to the app at runtime.
EXPO_PUBLIC_API_ORIGIN=https://your-api-origin.example.com
EXPO_PUBLIC_APPLE_TEAM_ID=YOUR_APPLE_TEAM_ID
EXPO_PUBLIC_IOS_APP_GROUP=group.com.your-app.app-group
REVENUECAT_APPLE_PUBLIC_SDK_KEY=appl_your_revenuecat_public_sdk_key
REVENUECAT_GOOGLE_PUBLIC_SDK_KEY=goog_your_revenuecat_public_sdk_key

# Server-only secrets
# Do not expose these through EXPO_PUBLIC_ or Expo `extra`.
OPENROUTER_API_KEY=sk-or-your-openrouter-server-key
